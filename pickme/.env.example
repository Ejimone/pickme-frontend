# PickMe frontend env template. Copy to .env and fill in.
# EXPO_PUBLIC_* vars are embedded in the client bundle (public by design) —
# only ever put PUBLIC values here (Clerk publishable key, not the secret key).

# Clerk publishable key (https://dashboard.clerk.com → API Keys)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# Backend REST base (must end in /api/v1) and WebSocket base (no /api/v1)
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
EXPO_PUBLIC_WS_URL=ws://localhost:8000
